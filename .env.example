# ── UniFi Protect NVR connection ─────────────────────────────────────────
# IP or hostname of your UniFi Protect Console (UDM Pro, CloudKey, UNVR)
PROTECT_HOST=
PROTECT_PORT=443

# Local NVR account (NOT a Ubiquiti Cloud / SSO account)
PROTECT_USERNAME=
PROTECT_PASSWORD=

# Set to "1" to verify the NVR's TLS certificate. Leave empty for self-signed.
SSL_VERIFY=

# ── Doorbell selection (all optional) ────────────────────────────────────
# Direct camera ID (24-char hex). Overrides auto-discovery if set.
PROTECT_CAMERA_ID=

# Filter by name (case-insensitive substring) if multiple doorbells exist.
DOORBELL_NAME=

# Filter by MAC address (with or without separators).
DOORBELL_MAC=

# ── Web server ───────────────────────────────────────────────────────────
SERVER_PORT=8080

# Set to "1" to enable HTTPS. SSL_KEY / SSL_CERT must then point to PEM files.
HTTPS=
SSL_KEY=certs/key.pem
SSL_CERT=certs/cert.pem

# ── Logging ──────────────────────────────────────────────────────────────
# debug | info | warning | error
LOG_LEVEL=info
